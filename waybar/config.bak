{
    "layer": "top",
    "position": "top",
    "height": 34,
    "spacing": 4,
    "modules-left": ["sway/workspaces", "sway/mode"],
    "modules-center": ["group/media", "sway/window"],
    "modules-right": ["pulseaudio", "backlight", "network", "bluetooth", "battery", "clock", "tray"],

    "sway/workspaces": {
        "disable-scroll": true,
        "all-outputs": true,
        "format": "{name}",
	    "persistent-workspaces": {
            "1": [],
            "2": [],
            "3": [],
            "4": [],
            "5": []
        }
    },
    "clock": {
        "format": "´Çù  {:%H:%M}",
        "format-alt": "´ü│  {:%A, %d %B %Y}",
        "tooltip-format": "<tt><small>{calendar}</small></tt>"
    },
    "network": {
        "format-wifi": "¾░ñ¿  {essid}",
        "format-ethernet": "¾░êÇ  LAN",
        "format-linked": "¾░êü  Wired",
        "format-disconnected": "¾░îÖ  Offline",
        "tooltip-format": "IP: {ipaddr} | Interfa╚ø─â: {ifname}"
    },
    "bluetooth": {
        "format": "¾░é»  {status}",
        "format-disabled": "¾░é▓  Off",
        "format-connected": "¾░é▒  {device_alias}",
        "tooltip-format": "{controller_alias}\t{controller_address}\n\nConexiuni: {num_connections}",
        "on-click": "blueman-manager"
    },
    "battery": {
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "{icon}  {capacity}%",
        "format-charging": "¾░éä  {capacity}%",
        "format-plugged": "¾░ÜÑ  {capacity}%",
        "format-icons": ["¾░éÄ", "¾░ü║", "¾░ü¢", "¾░éÇ", "¾░ü╣"],
        "tooltip-format": "Remaining: {time}\nUsing: {power} W"
    },
    "pulseaudio": {
        "format": "{icon}  {volume}%",
        "format-bluetooth": "´èö  {volume}%",
        "format-muted": "¯╗¿ Muted",
        "format-icons": {
            "headphone": "´ÇÑ",
            "default": ["´Çª", "´Çº", "´Ç¿"]
        },
        "on-click": "pavucontrol"
    },
    "backlight": {
        "format": "{icon}  {percent}%",
        "format-icons": ["´åà", "´äæ"]
    },
    "group/media": {
        "orientation": "horizontal",
        "drawer": {
            "transition-duration": 300,
            "transition-left-to-right": true
        },
        "modules": [
            "custom/music-icon",
            "mpris"
        ]
    },
    "custom/music-icon": {
        "format": "¾░ØÜ",
        "tooltip": false
    },
    "mpris": {
        "format": "{status_icon} {artist} - {title}",
        "max-length": 45,
        "status-icons": {
            "paused": "ÔûÂ",
            "playing": "ÔÅ©"
        }
    }
}
