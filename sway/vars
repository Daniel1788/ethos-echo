# - --------- -
# - Variables -
# - --------- -

set {
    # Logo key. Use Mod1 for Alt
    $mod Mod4
    $modAlt Mod1

    # Home row direction keys, like vim
    $left h
    $down j
    $up k
    $right l

    # Your preferred terminal emulator
    $term foot

    # Your preferred application launcher
    $menu fuzzel --background-color=282828ff --text-color=ebdbb2ff --selection-color=d79921ff --selection-text-color=282828ff --border-color=d79921ff --border-width=2 --border-radius=5

    # Volume
    $cmd_volume_up wpctl set-volume @DEFAULT_AUDIO_SINK@ 0.05+
    $cmd_volume_down wpctl set-volume @DEFAULT_AUDIO_SINK@ 0.05-
    $cmd_volume_mute exec wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle
    $cmd_mic_mute exec wpctl set-mute @DEFAULT_AUDIO_SOURCE@ toggle

    # Brightness
    $cmd_brightness_up brightnessctl set 2%+
    $cmd_brightness_down brightnessctl set 2%-
}

