# Scroll speed
input type:pointer scroll_factor 1

# Touchpad
input "1267:12632:ELAN050A:01_04F3:3158_Touchpad" {
       dwt enabled
       tap enabled
       natural_scroll enabled
       middle_emulation enabled
   }

# Keyboard
input type:keyboard {
    # xkb_layout ""
    # xkb_model ""
    # xkb_variant ""
}

input "HHKB*" {
    xkb_options ""
}

