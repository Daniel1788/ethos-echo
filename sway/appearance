# - --------- -
# - Wallpaper -
# - --------- -

output * bg ~/Pictures/background.jpg fill 
# fill|tile|centered|...


# Colors (gruvbox)
# class                 border  bground text    indicator child_border
client.focused          #d79921 #282828 #ebdbb2 #d79921   #d79921
client.focused_inactive #3c3836 #3c3836 #a89984 #3c3836   #3c3836
client.unfocused        #282828 #282828 #a89984 #282828   #282828
client.urgent           #cc241d #cc241d #ebdbb2 #cc241d   #cc241d
client.placeholder      #000000 #0c0c0c #ebdbb2 #000000   #0c0c0c

# Font
font monospace 10
# adjust this to change titlebar size
font pango:MesloLGS Nerd Font 10

# Cursor
# Name of the cursor theme directory in ~/.icons
set $cursor_theme Adwaita
set $cursor_size 24
seat seat0 xcursor_theme $cursor_theme $cursor_size

# GTK Theme
# https://github.com/swaywm/sway/wiki/GTK-3-settings-on-Wayland#setting-values-in-gsettings
exec_always {
    gsettings set org.gtk.Settings.FileChooser window-size '(1200, 700)'
    gsettings set org.gnome.desktop.interface gtk-theme 'Gruvbox-Dark'
    gsettings set org.gnome.desktop.interface icon-theme 'Gruvbox-Plus-Dark'
    gsettings set org.gnome.desktop.interface font-name 'Inter Semi-Bold'
    gsettings set org.gnome.desktop.interface cursor-theme $cursor_theme
    gsettings set org.gnome.desktop.interface cursor-size $cursor_size
    gsettings set org.gnome.desktop.interface color-scheme 'prefer-dark'
}

# Gaps
smart_gaps on
gaps outer 2
gaps inner 8

# Titlebar and border configuration
default_border pixel 2
default_floating_border normal
smart_borders on


# Window Titlebar
titlebar_padding 10 4
title_align center # left|right|center
# with title
for_window [class=".*"] title_format "<span rise='1000' font='sans 10'>%title</span>"
# without title
# for_window [class=".*"] title_format "<span></span>" # w/o title

# Disable titlebar for certain windows
for_window {
    [app_id="zen"] border pixel 2
    [app_id="foot"] border pixel 2
    [app_id="firefox"] border pixel 2
    [app_id="chromium"] border pixel 2
    [class="Brave-browser"] border pixel 2
    [app_id="blueman-manager"] border pixel 2
    [app_id="pavucontrol"] border pixel 2
}

